# OS junk
.DS_Store

# Obsidian cache + noisy UI state
.obsidian/cache/
.obsidian/workspace*
.obsidian/graph.json
.obsidian/backlink.json

# Optional: ignore plugin-specific transient files (tweak per your plugins)
.obsidian/plugins/*/data.json
# big/raw ops archive stuff (don’t track)
_files_ops/

# common large exports/backups
**/*.backup
**/*.sqlite3
_files_ops/**/*.csv

# ignore raw OnSong archive exports (stored outside repo)
_files_ops/OnSong-raw-source-data-ARCHIVE/
_files_ops/**/*.sqlite3
_files_ops/**/*.backup
